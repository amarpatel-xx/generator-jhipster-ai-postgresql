{
  "name": "generator-jhipster-ai-postgresql",
  "version": "2.0.19",
  "description": "Decription for Multiple Human Readable Foreign Key Fields",
  "keywords": [
    "yeoman-generator",
    "jhipster-blueprint",
    "human-readable foreign keys",
    "postgresql",
    "jhipster-8"
  ],
  "author": "Amar Premsaran Patel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amarpatel-xx/generator-jhipster-ai-postgresql.git"
  },
  "bugs": {
    "url": "https://github.com/amarpatel-xx/generator-jhipster-ai-postgresql/issues"
  },
  "homepage": "https://github.com/amarpatel-xx/generator-jhipster-ai-postgresql#readme",
  "type": "module",
  "bin": {
    "jhipster-ai-postgresql": "cli/cli.cjs"
  },
  "files": [
    "cli",
    "generators"
  ],
  "scripts": {
    "ejslint": "ejslint generators/**/*.ejs",
    "lint": "eslint .",
    "lint-fix": "npm run ejslint && npm run lint -- --fix",
    "prepare": "husky",
    "prettier-check": "prettier --check \"{,**/}*.{md,json,yml,html,js,ts,tsx,css,scss,vue,java}\"",
    "prettier-format": "prettier --write \"{,**/}*.{md,json,yml,html,js,ts,tsx,css,scss,vue,java}\"",
    "pretest": "npm run prettier-check && npm run lint",
    "test": "vitest run",
    "update-snapshot": "vitest run --update",
    "vitest": "vitest"
  },
  "dependencies": {
    "generator-jhipster": "9.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "ejs-lint": "2.0.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "11.0.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4",
    "yeoman-test": ">=8.0.0-rc.1"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "cacheDirectories": [
    "node_modules"
  ]
}
